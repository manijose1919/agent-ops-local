# AgentOpsLocal — Environment Variables
# Copy this file to `.env` and adjust as needed.
# All variables are optional; the defaults give a working zero-config local setup.

# --- Server ---
HOST=0.0.0.0
PORT=8000

# --- Database ---
# Defaults to a local SQLite file (sqlite:///./agent_ops.db).
# Set a PostgreSQL URL to switch databases, e.g.:
# DATABASE_URL=postgresql://user:password@localhost:5432/agent_ops

# --- Daily budget guardrail ---
# Max USD spend per day. When > 0, ingestion returns HTTP 429 once the day's
# total cost exceeds this limit, and the dashboard shows a budget progress bar.
# DAILY_BUDGET=5.00

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8000

# --- Planned (not yet enforced; see Roadmap) ---
# API-key auth for the ingest endpoint is on the roadmap and not active yet.
# API_SECRET_KEY=generate_a_random_secure_string
